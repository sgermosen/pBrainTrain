<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BrainTrain.App.Core.ViewModels;assembly=BrainTrain.App.Core"
             x:Class="BrainTrain.App.Pages.WordSearchPage"
             x:DataType="vm:WordSearchViewModel"
             Style="{StaticResource PageStyle}">

    <ScrollView>
        <VerticalStackLayout Padding="16,32,16,24" Spacing="12">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button Text="✕" FontSize="18" BackgroundColor="Transparent"
                        TextColor="{AppThemeBinding Light={StaticResource MutedLight}, Dark={StaticResource MutedDark}}"
                        Command="{Binding ExitCommand}" />
                <Label Grid.Column="1" Text="🔤 Sopa de Letras" Style="{StaticResource TitleText}" FontSize="22"
                       HorizontalOptions="Center" VerticalOptions="Center" />
                <Label Grid.Column="2" Style="{StaticResource BodyText}" FontFamily="OpenSansSemibold" VerticalOptions="Center">
                    <Label.Text>
                        <MultiBinding StringFormat="{}{0}/{1}">
                            <Binding Path="FoundCount" />
                            <Binding Path="TotalWords" />
                        </MultiBinding>
                    </Label.Text>
                </Label>
            </Grid>

            <Label Text="Toca la primera y la última letra de cada palabra."
                   Style="{StaticResource SubtitleText}" FontSize="13" HorizontalTextAlignment="Center" />

            <!-- Cuadrícula 10×10 -->
            <Border Style="{StaticResource Card}" Padding="6">
                <FlexLayout BindableLayout.ItemsSource="{Binding Cells}" Wrap="Wrap" JustifyContent="Center">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="vm:LetterCell">
                            <Border StrokeShape="RoundRectangle 8" Margin="1"
                                    WidthRequest="33" HeightRequest="33"
                                    StrokeThickness="{Binding IsAnchor, Converter={StaticResource AnchorStroke}}"
                                    Stroke="{StaticResource Primary}"
                                    BackgroundColor="{Binding IsFound, Converter={StaticResource FoundColor}}">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:WordSearchViewModel}}, Path=TapCommand}"
                                        CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                                <Label Text="{Binding Letter}" FontSize="15" FontFamily="OpenSansSemibold"
                                       Style="{StaticResource BodyText}" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </FlexLayout>
            </Border>

            <!-- Palabras a encontrar -->
            <FlexLayout BindableLayout.ItemsSource="{Binding Words}" Wrap="Wrap" JustifyContent="Center">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="vm:WordItem">
                        <Border StrokeShape="RoundRectangle 12" StrokeThickness="0" Margin="4" Padding="10,6"
                                BackgroundColor="{Binding IsFound, Converter={StaticResource FoundColor}}">
                            <Label Text="{Binding Word}" FontSize="13" FontFamily="OpenSansSemibold"
                                   Style="{StaticResource BodyText}">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsFound}" Value="True">
                                        <Setter Property="TextDecorations" Value="Strikethrough" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </FlexLayout>

            <local:MinigameResultView xmlns:local="clr-namespace:BrainTrain.App.Pages" />
            <Button Text="Terminar y cobrar XP" Style="{StaticResource SecondaryButton}"
                    Command="{Binding FinishCommand}" IsVisible="{Binding IsFinished, Converter={StaticResource Invert}}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
