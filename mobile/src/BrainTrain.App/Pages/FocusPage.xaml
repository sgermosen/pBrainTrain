<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BrainTrain.App.Core.ViewModels;assembly=BrainTrain.App.Core"
             x:Class="BrainTrain.App.Pages.FocusPage"
             x:DataType="vm:FocusHubViewModel"
             Style="{StaticResource PageStyle}">

    <ScrollView>
        <VerticalStackLayout Padding="20,36,20,24" Spacing="14">
            <Label Text="🧘 Enfoque" Style="{StaticResource TitleText}" />
            <Label Text="Protocolos reales, con su nivel de evidencia a la vista. Elige según lo que necesitas ahora."
                   Style="{StaticResource SubtitleText}" />

            <Border Style="{StaticResource Card}">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoWorkCommand}" />
                </Border.GestureRecognizers>
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                    <Label Text="🎯" FontSize="34" VerticalOptions="Center" />
                    <VerticalStackLayout Grid.Column="1" Spacing="3">
                        <Label Text="Bloque de foco (trabajar / estudiar)" Style="{StaticResource BodyText}" FontFamily="OpenSansSemibold" FontSize="17" />
                        <Label Text="Una meta, cero interrupciones, 15–90 min y sonido de fondo opcional. La receta del estado de flow."
                               Style="{StaticResource SubtitleText}" FontSize="13" LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <Border Style="{StaticResource Card}">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoBreatheCommand}" />
                </Border.GestureRecognizers>
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                    <Label Text="🌬️" FontSize="34" VerticalOptions="Center" />
                    <VerticalStackLayout Grid.Column="1" Spacing="3">
                        <Label Text="Calmar y despejar la mente" Style="{StaticResource BodyText}" FontFamily="OpenSansSemibold" FontSize="17" />
                        <Label Text="Respiración guiada (suspiro fisiológico, caja, exhalación larga) y reinicio mental NSDR de 10 min."
                               Style="{StaticResource SubtitleText}" FontSize="13" LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <Border Style="{StaticResource Card}" BackgroundColor="{StaticResource Secondary}">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoScienceCommand}" />
                </Border.GestureRecognizers>
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                    <Label Text="🔬" FontSize="30" VerticalOptions="Center" />
                    <VerticalStackLayout Grid.Column="1" Spacing="3">
                        <Label Text="¿Y esto funciona? La ciencia" TextColor="{StaticResource Tertiary}" FontFamily="OpenSansSemibold" FontSize="16" />
                        <Label Text="Qué está probado, qué es evidencia mixta y qué es humo. Sin promesas mágicas."
                               TextColor="{StaticResource Tertiary}" FontSize="13" LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Grid>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
