<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BrainTrain.App.Core.ViewModels;assembly=BrainTrain.App.Core"
             x:Class="BrainTrain.App.Pages.SimonPage"
             x:DataType="vm:SimonViewModel"
             Style="{StaticResource PageStyle}">

    <ScrollView>
        <VerticalStackLayout Padding="20,32,20,24" Spacing="14">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button Text="✕" FontSize="18" BackgroundColor="Transparent"
                        TextColor="{AppThemeBinding Light={StaticResource MutedLight}, Dark={StaticResource MutedDark}}"
                        Command="{Binding ExitCommand}" />
                <Label Grid.Column="1" Text="🚦 Simón Dice" Style="{StaticResource TitleText}" FontSize="22"
                       HorizontalOptions="Center" VerticalOptions="Center" />
                <Label Grid.Column="2" Text="{Binding Round, StringFormat='Ronda {0}'}"
                       Style="{StaticResource SubtitleText}" FontSize="13" VerticalOptions="Center" />
            </Grid>

            <Label Text="{Binding StatusText}" Style="{StaticResource BodyText}" FontFamily="OpenSansSemibold"
                   HorizontalOptions="Center" />

            <Border Style="{StaticResource Card}" Padding="14">
                <FlexLayout BindableLayout.ItemsSource="{Binding Pads}" Wrap="Wrap" JustifyContent="Center">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="vm:SimonPad">
                            <Border StrokeShape="RoundRectangle 22" StrokeThickness="0" Margin="7"
                                    WidthRequest="132" HeightRequest="132"
                                    BackgroundColor="{Binding Color}"
                                    Opacity="{Binding IsLit, Converter={StaticResource LitOpacity}}">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SimonViewModel}}, Path=TapCommand}"
                                        CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </FlexLayout>
            </Border>

            <Button Text="▶️ Empezar" Style="{StaticResource PrimaryButton}" Command="{Binding StartCommand}"
                    IsVisible="{Binding IsPlaying, Converter={StaticResource Invert}}" />

            <local:MinigameResultView xmlns:local="clr-namespace:BrainTrain.App.Pages" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
