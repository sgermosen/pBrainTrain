<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BrainTrain.App.Core.ViewModels;assembly=BrainTrain.App.Core"
             x:Class="BrainTrain.App.Pages.Game2048Page"
             x:DataType="vm:Game2048ViewModel"
             Style="{StaticResource PageStyle}">

    <Grid RowDefinitions="Auto,Auto,*,Auto" Padding="20,32" RowSpacing="14">
        <Grid ColumnDefinitions="Auto,*,Auto">
            <Button Text="✕" FontSize="18" BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Light={StaticResource MutedLight}, Dark={StaticResource MutedDark}}"
                    Command="{Binding ExitCommand}" />
            <Label Grid.Column="1" Text="🔢 2048" Style="{StaticResource TitleText}" FontSize="22" HorizontalOptions="Center" VerticalOptions="Center" />
            <Border Grid.Column="2" Style="{StaticResource Card}" Padding="12,6">
                <Label Text="{Binding Score}" FontFamily="OpenSansSemibold" Style="{StaticResource BodyText}" />
            </Border>
        </Grid>

        <Label Grid.Row="1" Text="Desliza para mover las fichas. Fusiona números iguales."
               Style="{StaticResource SubtitleText}" FontSize="13" HorizontalTextAlignment="Center" />

        <!-- Tablero 4×4: desliza en cualquier dirección -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="10" VerticalOptions="Center">
            <Border.GestureRecognizers>
                <SwipeGestureRecognizer Direction="Up" Command="{Binding MoveCommand}" CommandParameter="up" />
                <SwipeGestureRecognizer Direction="Down" Command="{Binding MoveCommand}" CommandParameter="down" />
                <SwipeGestureRecognizer Direction="Left" Command="{Binding MoveCommand}" CommandParameter="left" />
                <SwipeGestureRecognizer Direction="Right" Command="{Binding MoveCommand}" CommandParameter="right" />
            </Border.GestureRecognizers>
            <FlexLayout BindableLayout.ItemsSource="{Binding Cells}" Wrap="Wrap" AlignItems="Center" JustifyContent="Center">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="vm:TileCell">
                        <Border StrokeShape="RoundRectangle 12" StrokeThickness="0" Margin="4"
                                WidthRequest="72" HeightRequest="72"
                                BackgroundColor="{Binding Value, Converter={StaticResource TileColor}}">
                            <Label Text="{Binding Display}" FontSize="22" FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource TextLight}"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </FlexLayout>
        </Border>

        <VerticalStackLayout Grid.Row="3" Spacing="8">
            <vmres:MinigameResultView xmlns:vmres="clr-namespace:BrainTrain.App.Pages" />
            <Button Text="Cobrar XP y salir" Style="{StaticResource SecondaryButton}"
                    Command="{Binding CashOutCommand}" IsVisible="{Binding IsFinished, Converter={StaticResource Invert}}" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>
