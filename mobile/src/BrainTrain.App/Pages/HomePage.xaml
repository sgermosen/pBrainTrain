<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BrainTrain.App.Core.ViewModels;assembly=BrainTrain.App.Core"
             xmlns:core="clr-namespace:BrainTrain.App.Core;assembly=BrainTrain.App.Core"
             x:Class="BrainTrain.App.Pages.HomePage"
             x:DataType="vm:HomeViewModel"
             Style="{StaticResource PageStyle}">

    <RefreshView Command="{Binding LoadCommand}" IsRefreshing="{Binding IsBusy}">
        <ScrollView>
            <VerticalStackLayout Padding="20,32,20,24" Spacing="16">

                <!-- Barra superior: avatar, nombre y estado -->
                <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10">
                    <Button Grid.Column="0" x:Name="AvatarButton" Text="🦊" FontSize="24"
                            WidthRequest="52" HeightRequest="52" CornerRadius="26"
                            BackgroundColor="{StaticResource Secondary}"
                            Command="{Binding GoProfileCommand}" />
                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="0">
                        <Label Text="{Binding Profile.DisplayName}" Style="{StaticResource BodyText}" FontFamily="OpenSansSemibold" />
                        <Label Text="{Binding StreakLabel}" Style="{StaticResource SubtitleText}" FontSize="13" />
                        <Label Text="{Binding LeagueLabel}" Style="{StaticResource SubtitleText}" FontSize="11" TextColor="{StaticResource Primary}" />
                    </VerticalStackLayout>
                    <Border Grid.Column="2" Style="{StaticResource Card}" Padding="10,6">
                        <HorizontalStackLayout Spacing="4">
                            <Label Text="❤️" FontSize="14" VerticalOptions="Center" />
                            <Label Text="{Binding LivesLabel}" FontSize="14" FontFamily="OpenSansSemibold"
                                   VerticalOptions="Center" Style="{StaticResource BodyText}" />
                        </HorizontalStackLayout>
                    </Border>
                    <Border Grid.Column="3" Style="{StaticResource Card}" Padding="10,6">
                        <HorizontalStackLayout Spacing="4">
                            <Label Text="🪙" FontSize="14" VerticalOptions="Center" />
                            <Label Text="{Binding Profile.Coins}" FontSize="14" FontFamily="OpenSansSemibold"
                                   VerticalOptions="Center" Style="{StaticResource BodyText}" />
                        </HorizontalStackLayout>
                    </Border>
                </Grid>

                <!-- Nivel y progreso -->
                <Border Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="8">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="{Binding Profile.Level, StringFormat='Nivel {0}'}" Style="{StaticResource BodyText}" FontFamily="OpenSansSemibold" />
                            <Label Grid.Column="1" Style="{StaticResource SubtitleText}" FontSize="13">
                                <Label.Text>
                                    <MultiBinding StringFormat="{}{0}/{1} XP">
                                        <Binding Path="Profile.XpIntoLevel" />
                                        <Binding Path="Profile.XpForNextLevel" />
                                    </MultiBinding>
                                </Label.Text>
                            </Label>
                        </Grid>
                        <ProgressBar Progress="{Binding LevelProgress}" ProgressColor="{StaticResource Primary}" />
                    </VerticalStackLayout>
                </Border>

                <!-- Test inicial de nivel (una sola vez) -->
                <Border Style="{StaticResource Card}" BackgroundColor="{StaticResource Amber}" IsVisible="{Binding NeedsCalibration}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="🧪 Descubre tu nivel" TextColor="#3A2B00" FontFamily="OpenSansSemibold" FontSize="17" />
                        <Label Text="10 preguntas rápidas (gratis) para calibrar tu dificultad y armar tu radar de habilidades."
                               TextColor="#3A2B00" FontSize="13" />
                        <Button Text="Hacer mi test" Style="{StaticResource PrimaryButton}" Command="{Binding PlayCalibrationCommand}" />
                    </VerticalStackLayout>
                </Border>

                <!-- Misiones del día -->
                <Label Text="🎁 Misiones de hoy" Style="{StaticResource TitleText}" FontSize="18" />
                <Label Text="{Binding QuestMessage}" TextColor="{StaticResource Success}" FontFamily="OpenSansSemibold"
                       IsVisible="{Binding QuestMessage, Converter={StaticResource NotNull}}" HorizontalTextAlignment="Center" />
                <VerticalStackLayout BindableLayout.ItemsSource="{Binding Quests}" Spacing="8">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="core:QuestDto">
                            <Border Style="{StaticResource Card}" Padding="12">
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                    <Label Text="{Binding Emoji}" FontSize="22" VerticalOptions="Center" />
                                    <VerticalStackLayout Grid.Column="1" Spacing="4">
                                        <Label Text="{Binding Name}" Style="{StaticResource BodyText}" FontSize="14" FontFamily="OpenSansSemibold" />
                                        <ProgressBar Progress="{Binding ., Converter={StaticResource QuestProgress}}" ProgressColor="{StaticResource Amber}" />
                                        <Label Style="{StaticResource SubtitleText}" FontSize="11">
                                            <Label.Text>
                                                <MultiBinding StringFormat="{}{0}/{1} · +{2} 🪙 +{3} XP">
                                                    <Binding Path="Progress" />
                                                    <Binding Path="Target" />
                                                    <Binding Path="CoinReward" />
                                                    <Binding Path="XpReward" />
                                                </MultiBinding>
                                            </Label.Text>
                                        </Label>
                                    </VerticalStackLayout>
                                    <Button Grid.Column="2" Style="{StaticResource AmberButton}" HeightRequest="40" WidthRequest="88"
                                            FontSize="13" VerticalOptions="Center"
                                            Text="{Binding ., Converter={StaticResource QuestButtonText}}"
                                            IsEnabled="{Binding ., Converter={StaticResource QuestClaimable}}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=ClaimQuestCommand}"
                                            CommandParameter="{Binding .}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>

                <!-- Reto del día -->
                <Border Style="{StaticResource Card}" BackgroundColor="{StaticResource Primary}">
                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="6">
                        <Label Text="⚡ Reto del día" TextColor="White" FontFamily="OpenSansSemibold" FontSize="18" />
                        <Label Grid.Row="1" Text="7 preguntas, gratis (no gasta vidas) y con bonus de XP. ¡Mantén tu racha!"
                               TextColor="#E4DEFF" FontSize="13" />
                        <Button Grid.Row="2" Grid.ColumnSpan="2" Margin="0,8,0,0"
                                Text="{Binding DailyCompleted, Converter={StaticResource DailyButtonText}}"
                                Style="{StaticResource AmberButton}"
                                Command="{Binding PlayDailyCommand}"
                                IsEnabled="{Binding DailyCompleted, Converter={StaticResource Invert}}" />
                    </Grid>
                </Border>

                <!-- Juego rápido y entrenamiento -->
                <Button Text="🎲 Partida rápida" Style="{StaticResource PrimaryButton}" Command="{Binding PlayQuickCommand}" />
                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                    <Button Text="🧠 Entrenamiento" Style="{StaticResource SecondaryButton}" Command="{Binding GoTrainingCommand}" />
                    <Button Grid.Column="1" Text="🧘 Enfoque" Style="{StaticResource SecondaryButton}" Command="{Binding GoFocusCommand}" />
                </Grid>
                <Button Text="⚔️ Duelos 1v1" Style="{StaticResource SecondaryButton}" Command="{Binding GoDuelsCommand}" />

                <!-- Categorías -->
                <Label Text="Categorías" Style="{StaticResource TitleText}" FontSize="20" Margin="0,8,0,0" />
                <FlexLayout BindableLayout.ItemsSource="{Binding Categories}" Wrap="Wrap" JustifyContent="SpaceBetween">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="core:CategoryDto">
                            <Border Style="{StaticResource Card}" Margin="0,0,0,12" WidthRequest="165" HeightRequest="110">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=PlayCategoryCommand}"
                                        CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                                <VerticalStackLayout Spacing="6">
                                    <Label Text="{Binding Emoji}" FontSize="28" />
                                    <Label Text="{Binding Name}" FontSize="14" FontFamily="OpenSansSemibold"
                                           Style="{StaticResource BodyText}" LineBreakMode="WordWrap" />
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </FlexLayout>

                <Label Text="{Binding Error}" TextColor="{StaticResource Danger}"
                       IsVisible="{Binding Error, Converter={StaticResource NotNull}}" HorizontalTextAlignment="Center" />

                <!-- Accesos -->
                <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="8" Margin="0,4,0,0">
                    <Button Text="🏆" FontSize="22" BackgroundColor="Transparent" Command="{Binding GoLeaderboardCommand}" />
                    <Button Grid.Column="1" Text="🎖️" FontSize="22" BackgroundColor="Transparent" Command="{Binding GoAchievementsCommand}" />
                    <Button Grid.Column="2" Text="🛒" FontSize="22" BackgroundColor="Transparent" Command="{Binding GoStoreCommand}" />
                    <Button Grid.Column="3" Text="⚙️" FontSize="22" BackgroundColor="Transparent" Command="{Binding GoSettingsCommand}" />
                </Grid>

            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>
</ContentPage>
